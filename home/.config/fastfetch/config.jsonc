// Reference: Caelestia's fastfetch config
{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "~/.config/fastfetch/fetch.txt",
        "type": "auto",
        "padding": { "top": 1, "left": 2, "right": 2 },
        "color": { "1": "blue" }
    },
    "display": {
        "separator": "  ",
        "color": { "keys": "blue", "output": "blue", "title": "blue" },
        "constants": ["\u001b[34m", "\u001b[34m"]
    },
    "modules": [
        "break",
        {
            "type": "custom",
            "key": "╭────Loom───────────────────────────╮"
        },
        {
            "type": "command",
            "key": "│ {$2}{$1}  user  ",
            "text": "echo $USER",
            "format": "{$2}{>22}{$1} │"
        },
        {
            "type": "kernel",
            "key": "│ {$2}󰌽{$1}  kernel",
            "format": "{$2}{release>22}{$1} │"
        },
        {
            "type": "os",
            "key": "│ {$2}{$1}  os    ",
            "format": "{$2}{name>22}{$1} │"
        },
        {
            "type": "wm",
            "key": "│ {$2}{$1}  wm    ",
            "format": "{$2}{>22}{$1} │"
        },
        {
            "type": "packages",
            "key": "│   pkgs  ",
            "format": "{all>22} │"
        },
        {
            "type": "disk",
            "key": "│ {$2}{$1}  disk  ",
            "folders": "/",
            "format": "{$2}{>22}{$1} │"
        },
        {
            "type": "custom",
            "key": "╰───────────────────────────────────╯"
        },
        {
            "type": "colors",
            "symbol": "circle",
        }
    ]
}
